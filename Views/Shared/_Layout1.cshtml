                                    <p><i class="fa fa-check text-primary me-3"></i>Visual Reports & Graphs</p>
                                    <p><i class="fa fa-check text-primary me-3"></i>Customizable Deadline Filters</p>
                                    <a href="" class="btn btn-primary py-3 px-5 mt-3">Read More</a>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-pane-2">
