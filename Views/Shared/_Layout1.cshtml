    <!-- Features Start -->
    <div class="container-xxl feature py-5">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.1s">
                    <p class="d-inline-block border rounded text-primary fw-semi-bold py-1 px-3">Why Choosing Us!</p>
                    <h1 class="display-5 mb-4">Few Reasons Why People Choosing Us!</h1>
                    <p class="mb-4">
                        With Premium Deadline Management, you can track deadlines for all of your clients in one place so you don’t miss any submissions,
                        which can lead to unhappy customers! Our user-friendly interface allows you to view your upcoming obligations and helps you to
                        plan ahead.
                    </p>
                    <a class="btn btn-primary py-3 px-5" href="">Explore More</a>
                </div>
                <div class="col-lg-6">
                    <div class="row g-4 align-items-center">
                        <div class="col-md-6">
                            <div class="row g-4">
                                <div class="col-12 wow fadeIn" data-wow-delay="0.3s">
                                    <div class="feature-box border rounded p-4">
                                        <i class="fa fa-check fa-3x text-primary mb-3"></i>
                                        <h4 class="mb-3">Effortless Tracking</h4>
                                        <p class="mb-3">
                                            Easily track Companies House filing deadlines 
                                            without the stress. Stay organized and never miss
                                            an important date.
                                        </p>
                                        <a class="fw-semi-bold" href="">
                                            Read More <i class="fa fa-arrow-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                                <div class="col-12 wow fadeIn" data-wow-delay="0.5s">
                                    <div class="feature-box border rounded p-4">
                                        <i class="fa fa-check fa-3x text-primary mb-3"></i>
                                        <h4 class="mb-3">No More Penalties</h4>
                                        <p class="mb-3">
                                            Avoid late submissions and costly fines with our smart deadline 
                                            management system. Keep your filings on time, every time.
                                        </p>
                                        <a class="fw-semi-bold" href="">
                                            Read More <i class="fa fa-arrow-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 wow fadeIn" data-wow-delay="0.7s">
