<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Service") - Premium Deadline Management</title>
    <meta name="description" content="Premium Deadline Management service details for accountancy teams managing Companies House filing deadlines." />
    <link rel="icon" href="~/finanza-1.0.0/img/logo.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Rethink+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link href="~/finanza-1.0.0/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/service-pages.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
    <link href="~/css/responsive-overrides.css" rel="stylesheet" />
    <link href="~/css/cookie-consent.css" rel="stylesheet" />
</head>

<body class="service-layout-body">
    @await Html.PartialAsync("_UnifiedHeader")

    <div id="app">
        @RenderBody()
    </div>

    @await Html.PartialAsync("_UnifiedFooter")

    @await Html.PartialAsync("_CookieConsent")

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
    <script src="~/js/cookie-consent.js"></script>
</body>
</html>

