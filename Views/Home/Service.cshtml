@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
    ViewData["Title"] = "Services";
}

<main class="service-page">
    <div class="service-container">
        <section class="service-hero">
            <div class="service-copy">
                <span class="service-kicker"><i class="fa-solid fa-layer-group"></i> Our Services</span>
                <h1 class="service-title">Deadline management built for Companies House compliance</h1>
                <p class="service-summary">Stay ahead of every filing with a system designed for accuracy, visibility, and zero missed deadlines. Our platform syncs directly with Companies House to give you real-time insights, automated tracking, and complete control over your compliance workflow.</p>

                <div class="service-tags">
                    <span class="service-tag">Practical workflows</span>
                    <span class="service-tag">Clear visibility</span>
                    <span class="service-tag">Built for accountants</span>
                </div>

                <div class="service-actions">
                    <a class="service-btn service-btn-primary" href="/Contact">Book a demo</a>
                    <a class="service-btn service-btn-secondary" href="/Account/Signup">Create account</a>
                </div>
            </div>

            <div class="service-visual">
                <div class="service-visual-frame">
                    <img src="~/skywave/services.png" alt="Premium Deadline Management service overview" />
                </div>
            </div>
        </section>

        <section class="service-section">
            <div class="service-section-head">
                <span class="service-section-label">Core Services</span>
                <h2>Everything needed to manage filing deadlines with less pressure and more control.</h2>
                <p>Choose a service page below to see the workflow structure, included capabilities, and the operational benefit for your practice.</p>
            </div>

            <div class="service-cards">
                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-list-check"></i></span>
                    <h3>Client Deadline Prioritisation</h3>
                    <p>Surface the filings that need attention first so your team can plan earlier and respond before pressure builds.</p>
                    <a class="service-card-link" href="/Service/ClientDeadlinePrioritisation">View details <i class="fa-solid fa-arrow-right"></i></a>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-chart-column"></i></span>
                    <h3>Deadline Status Visualisation</h3>
                    <p>Use visual reporting to assess overdue and upcoming obligations quickly and support clearer daily reviews.</p>
                    <a class="service-card-link" href="/Service/DeadlineStatusVisualization">View details <i class="fa-solid fa-arrow-right"></i></a>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-link"></i></span>
                    <h3>Companies House Sync</h3>
                    <p>Keep records cleaner and reduce manual reconciliation by syncing core company information more reliably.</p>
                    <a class="service-card-link" href="/Service/CompaniesHouseSync">View details <i class="fa-solid fa-arrow-right"></i></a>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-diagram-project"></i></span>
                    <h3>Easier Workflow</h3>
                    <p>Centralise client deadline activity into one portal so staff can work from a simpler and more consistent process.</p>
                    <a class="service-card-link" href="/Service/WorkflowEasier">View details <i class="fa-solid fa-arrow-right"></i></a>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-calendar-check"></i></span>
                    <h3>Auto Deadline Tracking</h3>
                    <p>Keep Accounts and CS01 dates up to date inside the portal without repeated manual checking.</p>
                    <a class="service-card-link" href="/Service/AutoDeadlineTracking">View details <i class="fa-solid fa-arrow-right"></i></a>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-headset"></i></span>
                    <h3>Implementation Support</h3>
                    <p>Get practical guidance on setup, adoption, and the best way to fit the platform into your current process.</p>
                    <a class="service-card-link" href="/Contact">Talk to support <i class="fa-solid fa-arrow-right"></i></a>
                </article>
            </div>
        </section>

        <section class="service-section">
            <div class="service-band">
                <div>
                    <h2>Need help choosing the right service combination?</h2>
                    <p>We can recommend a setup based on your firm size, submission volume, and current deadline management workflow.</p>
                </div>
                <a class="service-btn service-btn-secondary" href="/Contact">Speak to our team</a>
            </div>
        </section>
    </div>
</main>
