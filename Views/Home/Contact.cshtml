@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

@section Styles {
<style>
    .pdm-contact-section {
        padding-top: 30px !important;
    }

    body > .container-fluid.footer,
    body > .container-fluid.copyright {
        display: none !important;
    }

    .pdm-contact-footer {
        background: #0f1f45;
        color: #dbe5ff;
        padding: 48px 0 24px;
    }

    .pdm-contact-footer a {
        color: inherit;
        text-decoration: none;
    }

    .pdm-contact-footer .footer-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
    }

    .pdm-contact-footer .footer-copy {
        margin-top: 24px;
        padding-top: 14px;
        border-top: 1px solid rgba(171, 191, 240, 0.25);
        display: flex;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        font-size: 12px;
        color: #a8b8e6;
    }

    @@media (max-width: 1020px) {
        .pdm-contact-footer .footer-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 680px) {
        .pdm-contact-footer .footer-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
}

<div class="container-fluid page-header mb-5 wow fadeIn text-white" data-wow-delay="0.1s">
    @* <div class="container">
        <h1 class="display-3 mb-4 animated slideInDown text-white">Contact</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-white">Home</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">Contact</li>
            </ol>
        </nav>
    </div> *@
</div>

<div class="container-xxl py-5 pdm-contact-section">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <p class="d-inline-block border rounded text-primary fw-semi-bold py-1 px-3">Contact</p>
                <h1 class="display-5 mb-4">Speak with our compliance specialists</h1>
                <p class="mb-4">
                    Whether you need help with Companies House deadlines, onboarding, or setup guidance,
                    our team is ready to support your practice with clear answers and practical next steps.
                </p>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <div class="bg-light rounded p-4 h-100">
                            <p class="mb-2 fw-semi-bold">
                                <i class="fa fa-phone-alt text-primary me-2"></i>
                                Call us directly
                            </p>
                            <h5 class="mb-2">+0208 087 2245</h5>
                            <p class="mb-0 text-muted">9.00 am to 9.00 pm, Monday to Saturday.</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="bg-light rounded p-4 h-100">
                            <p class="mb-2 fw-semi-bold">
                                <i class="fa fa-envelope text-primary me-2"></i>
                                Email support
                            </p>
                            <h6 class="mb-2">info@premiumaccountants.co.uk</h6>
                            <p class="mb-0 text-muted">For account enquiries and setup support.</p>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    <a class="btn btn-primary py-2 px-4" href="tel:+02080872245">Call Now</a>
                    <a class="btn btn-outline-primary py-2 px-4" href="mailto:info@premiumaccountants.co.uk">Send Email</a>
                </div>

                <form>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="name" placeholder="Your Name">
                                <label for="name">Your Name</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="email" class="form-control" id="email" placeholder="Your Email">
                                <label for="email">Your Email</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="subject" placeholder="Subject">
                                <label for="subject">Subject</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <textarea class="form-control" placeholder="Leave a message here" id="message" style="height: 110px"></textarea>
                                <label for="message">Message</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary py-3 px-5" type="submit">Send Message</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s" style="min-height: 450px;">
                <div class="position-relative rounded overflow-hidden h-100">
                    <iframe class="position-relative w-100 h-100"
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d19800.27208823619!2d-0.1323508!3d51.509865!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48761b3338e6e4e5%3A0xe7b53d1caa79070!2sLondon%2C%20UK!5e0!3m2!1sen!2suk!4v1712641111111!5m2!1sen!2suk"
                            frameborder="0"
                            style="min-height: 450px; border:0;"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            title="Premium Deadline Management location map"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="pdm-contact-footer">
    <div class="container">
        <div class="footer-grid">
            <div>
                <h3 style="margin:0;font-size:18px;color:#fff;">Our Office</h3>
                <p style="margin:10px 0 0;"><i class="fa-solid fa-location-dot"></i> London, UK</p>
                <p style="margin:8px 0 0;"><i class="fa-solid fa-phone"></i> +0208 087 2245</p>
                <p style="margin:8px 0 0;"><i class="fa-solid fa-envelope"></i> info@premiumaccountants.co.uk</p>
            </div>
            <div>
                <h3 style="margin:0;font-size:18px;color:#fff;">Services</h3>
                <a href="/Service/ClientDeadlinePrioritisation" style="display:block;margin-top:10px;">Client Deadline Prioritisation</a>
                <a href="/Service/DeadlineStatusVisualization" style="display:block;margin-top:8px;">Deadline Status Visualisation</a>
                <a href="/Service/WorkflowEasier" style="display:block;margin-top:8px;">Workflow Easier</a>
                <a href="/Service/AutoDeadlineTracking" style="display:block;margin-top:8px;">Auto Deadline Tracking</a>
            </div>
            <div>
                <h3 style="margin:0;font-size:18px;color:#fff;">Quick Links</h3>
                <a href="/About" style="display:block;margin-top:10px;">About Us</a>
                <a href="/Contact" style="display:block;margin-top:8px;">Contact Us</a>
                <a href="/Service" style="display:block;margin-top:8px;">Our Services</a>
                <a href="/Support" style="display:block;margin-top:8px;">Support</a>
                <a href="/Term&Condition" style="display:block;margin-top:8px;">Terms and Conditions</a>
            </div>
            <div>
                <h3 style="margin:0;font-size:18px;color:#fff;">Newsletter</h3>
                <p style="margin:10px 0 0;">Stay updated with our latest news and updates.</p>
                <div style="display:flex;gap:8px;margin-top:10px;">
                    <input type="email" placeholder="Your email" style="flex:1;min-width:0;border:1px solid #385496;background:#112658;color:#fff;border-radius:9px;padding:10px 12px;" />
                    <button type="button" style="border:0;border-radius:9px;background:#1a6de6;color:#fff;padding:0 14px;font-weight:700;">Send</button>
                </div>
            </div>
        </div>
        <div class="footer-copy">
            <span>&copy; 2026 Premium Deadline Management. All rights reserved.</span>
            <span>Designed by <a href="https://mt-london.co.uk/" target="_blank" rel="noreferrer">Micro Tech London</a></span>
        </div>
    </div>
</footer>
