@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
    ViewData["Title"] = "Client Deadline Prioritisation";
}

<main class="service-page">
    <div class="service-container">
        <section class="service-hero">
            <div class="service-copy">
                <span class="service-kicker"><i class="fa-solid fa-layer-group"></i> Service Detail</span>
                <h1 class="service-title">Client deadline prioritisation that keeps urgent filings in view.</h1>
                <p class="service-summary">When your practice is managing a large portfolio, the biggest challenge is knowing which Companies House obligations need attention first. Client Deadline Prioritisation helps your team focus on the filings that carry the highest risk, so you can plan better, respond earlier, and stay ahead of avoidable pressure.</p>

                <div class="service-tags">
                    <span class="service-tag">Risk-based ranking</span>
                    <span class="service-tag">Portfolio visibility</span>
                    <span class="service-tag">Practical planning</span>
                </div>

                <div class="service-actions">
                    <a class="service-btn service-btn-primary" href="/Contact">Book a consultation</a>
                    <a class="service-btn service-btn-secondary" href="/Account/Signup">Create account</a>
                </div>
            </div>

            <div class="service-visual">
                <div class="service-visual-frame">
                    <img src="~/finanza-1.0.0/img/Never Miss a Deadline Again.png" alt="Client deadline prioritisation dashboard preview" />
                </div>
            </div>
        </section>

        <section class="service-section">
            <div class="service-section-head">
                <span class="service-section-label">What This Service Covers</span>
                <h2>Bring the most urgent deadline work to the top of your team's workflow.</h2>
                <p>This service is designed for firms that cannot afford to rely on manual lists, inbox reminders, or scattered spreadsheets. It highlights priority filings clearly, helping staff make faster decisions and allocate effort where it matters most.</p>
            </div>

            <div class="service-split">
                <article class="service-panel">
                    <h3>How it helps</h3>
                    <p>Instead of reviewing every client in the same way, your team can work from a smarter order of priority. That means less time deciding what to do next and more time completing submissions before they become urgent.</p>
                    <p>With stronger visibility across your client base, it becomes easier to spot pressure points early, protect service quality, and reduce the chance of missed Companies House filings.</p>
                </article>

                <article class="service-panel is-soft">
                    <h3>Included capabilities</h3>
                    <ul class="service-checklist">
                        <li><i class="fa-solid fa-circle-check"></i><span>Priority-based deadline ranking across your portfolio</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Clear escalation for high-risk or overdue filings</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Focused workload planning for busy submission periods</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Visibility across hundreds of clients in one place</span></li>
                    </ul>
                </article>
            </div>
        </section>

        <section class="service-section">
            <div class="service-cards">
                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                    <h3>Clear urgency</h3>
                    <p>Your team can immediately see which filings need action first, reducing hesitation and improving response times.</p>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-list-check"></i></span>
                    <h3>Smarter workload</h3>
                    <p>Organise tasks based on real deadline risk rather than guesswork, which makes capacity planning more reliable.</p>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-user-shield"></i></span>
                    <h3>Better client confidence</h3>
                    <p>Stronger prioritisation helps you stay consistent and dependable, even during periods of heavy filing volume.</p>
                </article>
            </div>
        </section>

        <section class="service-section">
            <div class="service-band">
                <div>
                    <h2>Need help building a smarter deadline queue?</h2>
                    <p>We can help configure a prioritised workflow that fits the way your practice manages filings.</p>
                </div>
                <a class="service-btn service-btn-secondary" href="/Contact">Speak to our team</a>
            </div>
        </section>
    </div>
</main>
