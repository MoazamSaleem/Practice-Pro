@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
    ViewData["Title"] = "Auto Deadline Tracking";
}

<main class="service-page">
    <div class="service-container">
        <section class="service-hero">
            <div class="service-copy">
                <span class="service-kicker"><i class="fa-solid fa-calendar-check"></i> Service Detail</span>
                <h1 class="service-title">Auto deadline tracking that keeps key filing dates current without manual chasing.</h1>
                <p class="service-summary">Auto Deadline Tracking helps your practice stay on top of essential Companies House due dates by keeping filing records up to date inside the portal. It reduces the risk of relying on stale information and gives teams a more dependable view of upcoming Accounts and CS01 obligations.</p>

                <div class="service-tags">
                    <span class="service-tag">Accounts deadlines</span>
                    <span class="service-tag">CS01 tracking</span>
                    <span class="service-tag">Always up to date</span>
                </div>

                <div class="service-actions">
                    <a class="service-btn service-btn-primary" href="/Contact">Book a consultation</a>
                    <a class="service-btn service-btn-secondary" href="/Account/Signup">Create account</a>
                </div>
            </div>

            <div class="service-visual">
                <div class="service-visual-frame">
                    <img src="~/finanza-1.0.0/img/Always-Up-To-Date Deadlines.png" alt="Automatic deadline tracking preview" />
                </div>
            </div>
        </section>

        <section class="service-section">
            <div class="service-section-head">
                <span class="service-section-label">What This Service Covers</span>
                <h2>Keep core Companies House filing dates aligned with less manual effort.</h2>
                <p>Firms often lose time checking whether dates have changed and updating records by hand. Auto Deadline Tracking reduces that burden and helps your team work from a more trustworthy set of deadlines across the portfolio.</p>
            </div>

            <div class="service-split">
                <article class="service-panel">
                    <h3>How it helps</h3>
                    <p>By keeping key due dates refreshed inside the platform, your team gains stronger day-to-day visibility without relying on repeated manual checks. That makes planning easier and reduces avoidable last-minute pressure.</p>
                    <p>The service is especially valuable for firms managing large volumes of companies where even small delays in updating records can lead to operational risk.</p>
                </article>

                <article class="service-panel is-soft">
                    <h3>Included capabilities</h3>
                    <ul class="service-checklist">
                        <li><i class="fa-solid fa-circle-check"></i><span>Accounts submission deadline tracking</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>CS01 confirmation statement tracking</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Due-date refreshes for better visibility</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Historical deadline reference inside the portal</span></li>
                    </ul>
                </article>
            </div>
        </section>

        <section class="service-section">
            <div class="service-cards">
                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-rotate"></i></span>
                    <h3>Automatic updates</h3>
                    <p>Keep important filing dates current without repeatedly revisiting records across different systems.</p>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-clock-rotate-left"></i></span>
                    <h3>Reliable records</h3>
                    <p>Work from fresher deadline information when reviewing status, planning work, and assigning follow-up tasks.</p>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-shield-halved"></i></span>
                    <h3>Stronger control</h3>
                    <p>Reduce the chance of missed deadlines caused by outdated dates or overlooked manual updates.</p>
                </article>
            </div>
        </section>

        <section class="service-section">
            <div class="service-band">
                <div>
                    <h2>Need a more dependable way to track Accounts and CS01 dates?</h2>
                    <p>We can help you implement an automatic tracking setup that fits your existing workflow.</p>
                </div>
                <a class="service-btn service-btn-secondary" href="/Contact">Speak to our team</a>
            </div>
        </section>
    </div>
</main>
