@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
    ViewData["Title"] = "Easier Workflow";
}

<main class="service-page">
    <div class="service-container">
        <section class="service-hero">
            <div class="service-copy">
                <span class="service-kicker"><i class="fa-solid fa-diagram-project"></i> Service Detail</span>
                <h1 class="service-title">A simpler workflow for managing client deadlines in one central portal.</h1>
                <p class="service-summary">Easier Workflow is built for accountancy teams that need less complication and more operational clarity. It centralises deadline management, keeps client activity visible, and helps your staff work from one consistent workflow rather than piecing information together from multiple places.</p>

                <div class="service-tags">
                    <span class="service-tag">Centralised dashboard</span>
                    <span class="service-tag">Real-time updates</span>
                    <span class="service-tag">Secure cloud access</span>
                </div>

                <div class="service-actions">
                    <a class="service-btn service-btn-primary" href="/Contact">Discuss your setup</a>
                    <a class="service-btn service-btn-secondary" href="/Account/Signup">Start free trial</a>
                </div>
            </div>

            <div class="service-visual">
                <div class="service-visual-frame">
                    <img src="~/finanza-1.0.0/img/Streamline Your Processes.png" alt="Workflow dashboard illustration" />
                </div>
            </div>
        </section>

        <section class="service-section">
            <div class="service-section-head">
                <span class="service-section-label">What This Service Covers</span>
                <h2>Give your team one cleaner process for tracking, reviewing, and acting on deadlines.</h2>
                <p>Many practices lose time to scattered records, repeated checks, and manual follow-ups. Easier Workflow reduces that friction by bringing core filing activity into a single environment that is easier to manage day to day.</p>
            </div>

            <div class="service-split">
                <article class="service-panel">
                    <h3>How it helps</h3>
                    <p>Instead of switching between disconnected tools, staff can work from a central dashboard that shows what is due, what is overdue, and what needs follow-up. This improves speed, consistency, and team coordination.</p>
                    <p>The result is a calmer workflow that supports better planning and lowers the chance of missed submissions caused by fragmented admin.</p>
                </article>

                <article class="service-panel is-soft">
                    <h3>Included capabilities</h3>
                    <ul class="service-checklist">
                        <li><i class="fa-solid fa-circle-check"></i><span>Centralised dashboard for all client deadlines</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Real-time deadline and status updates</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Secure cloud access for team-wide visibility</span></li>
                        <li><i class="fa-solid fa-circle-check"></i><span>Less manual chasing and reduced admin friction</span></li>
                    </ul>
                </article>
            </div>
        </section>

        <section class="service-section">
            <div class="service-cards">
                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-table-columns"></i></span>
                    <h3>Central workspace</h3>
                    <p>Bring client deadline activity into one place so staff can review and act without unnecessary switching.</p>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-people-group"></i></span>
                    <h3>Team alignment</h3>
                    <p>Shared visibility supports better communication, clearer ownership, and stronger coordination across the practice.</p>
                </article>

                <article class="service-card">
                    <span class="service-card-icon"><i class="fa-solid fa-gauge-high"></i></span>
                    <h3>Reduced admin drag</h3>
                    <p>Simpler workflows help your team move faster without sacrificing accuracy or compliance oversight.</p>
                </article>
            </div>
        </section>

        <section class="service-section">
            <div class="service-band">
                <div>
                    <h2>Want a workflow that is easier to manage under pressure?</h2>
                    <p>We can help shape a centralised process that suits the way your firm handles client filing activity.</p>
                </div>
                <a class="service-btn service-btn-secondary" href="/Contact">Speak to our team</a>
            </div>
        </section>
    </div>
</main>
