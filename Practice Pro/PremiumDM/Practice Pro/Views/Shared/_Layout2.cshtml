<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>PremiumDM - Financial Services</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C83CGLH9NR"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-C83CGLH9NR');
    </script>
    <!-- Favicon -->
    <link href="~/finanza-1.0.0/img/logo.jpg" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@500;600;700&family=Open+Sans:wght@400;500&display=swap"
          rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/finanza-1.0.0/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/finanza-1.0.0/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/finanza-1.0.0/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/finanza-1.0.0/css/style.css" rel="stylesheet">
</head>

<body>
    <!-- Spinner Start -->
    <div id="spinner"
         class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    </div>
    <!-- Spinner End -->
    <!-- Navbar Start -->
    <div class="container-fluid fixed-top px-0 wow fadeIn" data-wow-delay="0.1s">
        <div class="top-bar row gx-0 align-items-center d-none d-lg-flex" style="background-color:#007bff">
            <div class="col-lg-6 px-5 text-start">
                @* <small style="color: white;"> *@
                @*     <i class="fa fa-map-marker-alt me-2" style="color: white;"></i> 30 Connaught Avenue Hounslow London TW4 5BW *@
                @* </small> *@
                <small style="color: white;">
                    <i class="fa fa-envelope me-2" style="color: white;"></i> info@premiumaccountants.co.uk
                </small>
                <small class="ms-4" style="color: white;">
                    <i class="fa fa-clock me-2" style="color: white;"></i> 9.00 am - 9.00 pm
                </small>
            </div>
            <div class="col-lg-6 px-5 text-end">
                @* <small style="color: white;"> *@
                @*     <i class="fa fa-envelope me-2" style="color: white;"></i> info@premiumaccountants.co.uk *@
                @* </small> *@
                <small class="ms-4" style="color: white;">
                    <i class="fa fa-phone-alt me-2" style="color: white;"></i> +0208 087 2245
                </small>
                <!-- Social Media Icons -->
                <small class="ms-4">
                    <a href="https://www.facebook.com" target="_blank" style="color: white; margin-right: 10px;">
                        <i class="fab fa-facebook-f" style="font-size: 18px; padding: 5px; border-radius: 50%; border: 1px solid white; width: 30px; height: 30px; display: inline-flex; justify-content: center; align-items: center;"></i>
                    </a>
                    <a href="https://www.instagram.com" target="_blank" style="color: white; margin-right: 10px;">
                        <i class="fab fa-instagram" style="font-size: 18px; padding: 5px; border-radius: 50%; border: 1px solid white; width: 30px; height: 30px; display: inline-flex; justify-content: center; align-items: center;"></i>
                    </a>
                    <a href="https://www.twitter.com" target="_blank" style="color: white;">
                        <i class="fab fa-twitter" style="font-size: 18px; padding: 5px; border-radius: 50%; border: 1px solid white; width: 30px; height: 30px; display: inline-flex; justify-content: center; align-items: center;"></i>
                    </a>
                </small>
            </div>
        </div>
        <nav class="navbar navbar-expand-lg navbar-light py-lg-0 px-lg-5 wow fadeIn" data-wow-delay="0.1s" style="background-color:white">
            <div class="container-fluid">
                <!-- Logo at the left corner -->
                <a class="nav-item" asp-action="Index" asp-controller="Home">
                    <img src="~/finanza-1.0.0/img/logo.jpg" alt="Logo" class="img-fluid" style="height: 50px;">
                </a>

                <!-- Navbar toggler for mobile view -->
                <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse"
                        data-bs-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Centering navbar items -->
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <div class="navbar-nav ms-auto me-auto p-4 p-lg-0 flex-grow-1 justify-content-center">
                        <a class="nav-item nav-link" href="/">Home</a>
                        <a class="nav-item nav-link" href="/About">About</a>

                        <!-- Services Dropdown -->
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Services</a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="/Service/AutomatedDeadlineReminder">Automated Deadline Reminder</a>
                                <a class="dropdown-item" href="/Service/DeadlineStatusVisualization">Deadline Status Visualization</a>
                                <a class="dropdown-item" href="/Service/CompaniesHouseSync">Companies House Sync</a>
                                <a class="dropdown-item" href="/Service/WorkflowEasier">Workflow Easier</a>
                                <a class="dropdown-item" href="/Service/AutoDeadlineTracking">Auto Deadline Tracking</a>
                            </div>
                        </div>

                        <a class="nav-item nav-link" href="/Contact">Contact</a>
                    </div>

                    <!-- Login/Register or DashBoard at the right corner -->
                    <div class="navbar-nav me-auto p-4 p-lg-0">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a class="nav-item nav-link" href="/DashBoard">DashBoard</a>
                            <form id="logoutForm" method="post" asp-action="Logout" asp-controller="Account" class="navbar-nav">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-item nav-link" style="font-weight: bold;">
                                    <span class="text-danger">LOGOUT</span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="nav-link scrollto" asp-action="Login" asp-controller="Account"
                               style="background-color: #007bff; color: white; border-radius: 20px; padding: 10px 20px; transition: all 0.3s ease;">
                                <i class="fas fa-user-circle me-2"></i> Login/Register
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </div>
    <!-- Navbar End -->
    <div id="app">
        @RenderBody()
    </div>
    <!-- Footer Start -->
    <div class="container-fluid bg-dark text-light footer mt-5 py-5 wow fadeIn" data-wow-delay="0.1s">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Our Office</h4>
                    <p class="mb-2">
                        <i class="fa fa-map-marker-alt me-3"></i>London UK
                    </p>
                    <p class="mb-2"><i class="fa fa-phone-alt me-3"></i>+0208 087 2245</p>
                    <p class="mb-2"><i class="fa fa-envelope me-3"></i>info@premiumaccountants.co.uk</p>
                    <div class="d-flex pt-2">
                        <a class="btn btn-square btn-outline-light rounded-circle me-2" href="">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a class="btn btn-square btn-outline-light rounded-circle me-2" href="">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a class="btn btn-square btn-outline-light rounded-circle me-2" href="">
                            <i class="fab fa-youtube"></i>
                        </a>
                        <a class="btn btn-square btn-outline-light rounded-circle me-2" href="">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Services</h4>
                    <a class="btn btn-link" href="/Service/AutomatedDeadlineReminder">Automated Deadline Reminder</a>
                    <a class="btn btn-link" href="/Service/DeadlineStatusVisualization">Deadline Status Visualization</a>
                    <a class="btn btn-link" href="/Service/CompaniesHouseSync">Companies House Sync</a>
                    <a class="btn btn-link" href="/Service/WorkflowEasier">Workflow Easier</a>
                    <a class="btn btn-link" href="/Service/AutoDeadlineTracking">Auto Deadline Tracking</a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Quick Links</h4>
                    <a class="btn btn-link" href="/About">About Us</a>
                    <a class="btn btn-link" href="/Contact">Contact Us</a>
                    <a class="btn btn-link" href="/Service">Our Services</a>
                    <a class="btn btn-link" href="/Support">Support</a>
                    <a class="btn btn-link" href="/Term&Condition">Term & Conditions</a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Newsletter</h4>
                    <p>Stay updated with our latest news and updates.</p>

                    <div class="position-relative w-100">
                        <input id="emailInput" class="form-control bg-white border-0 w-100 py-3 ps-4 pe-5" type="text"
                               placeholder="Your email">
                        <button id="signUpBtn" type="button" class="btn btn-primary py-2 position-absolute top-0 end-0 mt-2 me-2">
                            Send Now
                        </button>
                    </div>

                    <!-- Success Message (Hidden by Default) -->
                    <div id="successMessage" class="mt-3 text-success fw-bold d-none">
                        ✅ Subscription Successful!
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->
    <!-- Copyright Start -->
    <div class="container-fluid copyright py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; <a class="border-bottom" href="#">Premium DeadLine Management</a>, All Right Reserved.
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <!--/*** This template is free as long as you keep the footer author’s credit link/attribution link/backlink. If you'd like to use the template without the footer author’s credit link/attribution link/backlink, you can purchase the Credit Removal License from "https://htmlcodex.com/credit-removal". Thank you for your support. ***/-->
                    Designed By <a class="border-bottom" href="https://mt-london.co.uk/">Micro Tech London</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Copyright End -->
    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square rounded-circle back-to-top">
        <i class="bi bi-arrow-up"></i>
    </a>


    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/finanza-1.0.0/lib/wow/wow.min.js"></script>
    <script src="~/finanza-1.0.0/lib/easing/easing.min.js"></script>
    <script src="~/finanza-1.0.0/lib/waypoints/waypoints.min.js"></script>
    <script src="~/finanza-1.0.0/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/finanza-1.0.0/lib/counterup/counterup.min.js"></script>

    <!-- Template Javascript -->
	<script src="~/finanza-1.0.0/js/main.js"></script>
	<script src="~/dist/build.js"></script>
</body>

</html>