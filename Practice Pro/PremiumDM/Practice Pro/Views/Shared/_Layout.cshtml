<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>PremiumDM</title>
    <meta content="" name="description">
    <meta content="" name="keywords">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C83CGLH9NR"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-C83CGLH9NR');
    </script>
    <!-- Favicons -->
    <link href="~/DevFolio/assets/img/logo.webp" rel="icon">

    <!-- Vendor CSS Files -->
    <link href="~/DevFolio/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/DevFolio/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/DevFolio/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="~/DevFolio/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">



    <!-- DataTables CSS -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="~/AdminLTE/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
    <link href="~/AdminLTE/plugins/toastr/toastr.css" rel="stylesheet" />
    <link href="~/adminlte/plugins/datatables-colreorder/css/colreorder.bootstrap4.min.css" rel="stylesheet" />

    <!-- Template Main CSS File -->
    <link href="~/DevFolio/assets/css/style.css" rel="stylesheet">
</head>

<body>

    <!-- ======= Header ======= -->
    <header id="header" class="fixed-top">
        <div class="container d-flex align-items-center justify-content-between">

            <a href="#hero">
                <img src="~/DevFolio/assets/img/logo.webp"
                     alt="PremiumDM Logo"
                     style="width: 200px; height: auto;" />
            </a>

            <nav id="navbar" class="navbar">
    <ul>
        <li><a class="nav-link scrollto" href="/" style="color:#0078ff">Home</a></li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li><a class="nav-link scrollto" asp-controller="Home" asp-action="Privacy" style="color:#0078ff">Dashboard</a></li>
                        <li><a class="nav-link scrollto" asp-controller="Client" asp-action="FavCompany" style="color:#0078ff">Companies</a></li>
                        <li><a class="nav-link scrollto" asp-controller="Client" asp-action="InCompany" style="color:#0078ff">Import Companies</a></li>

                        @if (User.HasClaim("IsAdmin", "true"))
                        {
                            <li><a class="nav-link scrollto" asp-controller="Admin" asp-action="RegisteredUsers" style="color:#0078ff">Registered Users</a></li>
                            <li><a class="nav-link scrollto" asp-controller="Admin" asp-action="UsersActivities" style="color:#0078ff">User Activities</a></li>
                        }

                        <li style="padding-top:6px">
                            <form id="logoutForm" method="post" asp-action="Logout" asp-controller="Account" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger p-0 m-0" style="font-weight: bold;">
                                    <i class="fas fa-sign-out-alt"></i> <span style="padding-left: 20px;">LOGOUT</span>
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li><a class="nav-link scrollto" asp-action="Login" asp-controller="Account">Login</a></li>
                        <li><a class="nav-link scrollto" asp-action="Signup" asp-controller="Account">Register</a></li>
                    }

    </ul>
    <i class="bi bi-list mobile-nav-toggle"></i>
</nav>



        </div>
    </header><!-- End Header -->
    <div id="app" class="my-5 py-5">
        @RenderBody()
    </div>
    <!-- ======= Footer ======= -->
    <footer>
        <div class="container">
            <div class="row">
                <div class="col-sm-12">
                    <div class="copyright-box">
                        <p class="copyright">&copy; Copyright <strong>PremiumDM</strong>. All Rights Reserved</p>
                        <div class="credits">
                            Designed by <a href="https://mt-london.co.uk/">Micro Tech London</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer><!-- End  Footer -->

    <div id="preloader"></div>
    <a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <!-- Scripts -->
    <script src="~/AdminLTE/plugins/jquery/jquery.min.js"></script>
    <script src="~/AdminLTE/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables Scripts -->
    <script src="~/AdminLTE/plugins/datatables/jquery.dataTables.js"></script>
    <script src="~/AdminLTE/plugins/datatables-bs4/js/dataTables.bootstrap4.js"></script>
    <script src="~/AdminLTE/plugins/datatables-responsive/js/dataTables.responsive.js"></script>

    <script src="~/adminlte/plugins/datatables-colreorder/js/colreorder.bootstrap4.min.js"></script>
    <script src="~/adminlte/plugins/datatables-colreorder/js/datatables.colreorder.min.js"></script>

    <!-- Vendor JS Files -->
    <script src="~/DevFolio/assets/vendor/purecounter/purecounter_vanilla.js"></script>
    <script src="~/DevFolio/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/DevFolio/assets/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="~/DevFolio/assets/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="~/DevFolio/assets/vendor/typed.js/typed.umd.js"></script>
    <script src="~/DevFolio/assets/vendor/php-email-form/validate.js"></script>
    <script src="~/dist/build.js"></script>
    <!-- Template Main JS File -->
    <script src="~/DevFolio/assets/js/main.js"></script>
</body>

</html>
<style>
    html, body {
        height: 100%;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    #app {
        flex: 1; /* Pushes footer to the bottom */
    }

    footer {
        text-align: center;
    }
</style>