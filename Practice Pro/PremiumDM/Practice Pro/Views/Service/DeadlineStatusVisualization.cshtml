@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
}
<div class="mt-5 mb-5 pt-5 pb-5">
    <!-- First spacer -->
    <div class="mt-6 mb-6 pt-6 pb-6">
        <!-- Second spacer -->
        <div class="container-xxl py-5 mt-8">
            <!-- Content container -->
            <div class="container">
                <div class="row g-5 align-items-center">
                    <!-- Image Column -->
                    <div class="col-lg-5 col-md-6 col-12">
                        <img class="img-fluid rounded w-100" src="~/finanza-1.0.0/img/Deadline Status & Real-Time Progress Tracking.png" alt="Visual Dashboard">
                    </div>

                    <!-- Text Content Column -->
                    <div class="col-lg-7 col-md-6 col-12">
                        <h2 class="mb-4">At-a-Glance Deadline Status & Real-Time Progress Tracking</h2>
                        <p class="mb-4">
                            Stay on top of your projects with our intuitive dashboard designed to provide instant clarity.
                            With just a quick glance, you can see which tasks are overdue, what’s due soon, and what’s already been completed.
                            Our platform empowers teams to stay aligned, prioritize work more effectively, and avoid missed deadlines.
                            Perfect for businesses, project managers, and teams aiming for operational excellence.
                        </p>

                        <div class="service-features mb-4">
                            <p><i class="fa fa-check text-primary me-2"></i> Color-coded priority system for quick status recognition</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Customizable date ranges to suit your workflow</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Exportable reports for performance analysis and sharing</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Real-time updates to keep everyone on the same page</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Seamless integration with your existing tools and systems</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>