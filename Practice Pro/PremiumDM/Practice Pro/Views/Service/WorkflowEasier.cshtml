@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
}
<div class="mt-5 mb-5 pt-5 pb-5">
    <!-- First spacer -->
    <div class="mt-6 mb-6 pt-6 pb-6">
        <!-- Second spacer -->
        <div class="container-xxl py-5 mt-8">
            <!-- Content container -->
            <div class="container">
                <div class="row g-5 align-items-center">
                    <!-- Image Column -->
                    <div class="col-lg-5 col-md-6 col-12">
                        <img class="img-fluid rounded w-100" src="~/finanza-1.0.0/img/Streamline Your Processes.png" alt="Workflow Management" style="border: 1px solid #dee2e6;">
                    </div>

                    <!-- Content Column -->
                    <div class="col-lg-7 col-md-6 col-12">
                        <h2 class="mb-4">Streamline Your Processes</h2>
                        <p class="mb-4">
                            Our platform is designed to simplify and enhance the way your company handles client workflows and compliance tracking. By integrating directly with Companies House, we remove the hassle of manual data entry and provide real-time visibility into important deadlines, filings, and document updates. This allows your team to focus more on strategic work and less on repetitive tasks.
                        </p>
                        <p class="mb-4">
                            Whether you're managing a few clients or hundreds, our system provides a scalable solution that grows with your business. The intuitive interface offers a unified view of all client data in one place — reducing the risk of errors and missed deadlines.
                        </p>
                        <p class="mb-4">
                            Our tool doesn’t just help you manage information, it transforms how your team works. With built-in features for internal collaboration, task assignment, and automated document linking, your operations become smoother and more transparent across departments.
                        </p>

                        <div class="service-features mb-4">
                            <p><i class="fa fa-check text-primary me-2"></i> Real-time integration with Companies House</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Unified client management dashboard</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Automated document generation and linking</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Collaboration tools for seamless teamwork</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Customizable alerts and deadline reminders</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
