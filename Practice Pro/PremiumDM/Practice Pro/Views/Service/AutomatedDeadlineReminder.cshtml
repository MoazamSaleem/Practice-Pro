@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
}
<!-- Service Content -->
<div class="mt-5 mb-5 pt-5 pb-5">
    <!-- First spacer -->
    <div class="mt-6 mb-6 pt-6 pb-6">
        <!-- Second spacer -->
        <div class="container-xxl py-5 mt-8">
            <!-- Content container -->
            <div class="container">
                <div class="row g-5 align-items-center">
                    <!-- Image Column -->
                    <div class="col-lg-5 col-md-6 col-12">
                        <img class="img-fluid rounded w-100" src="~/finanza-1.0.0/img/Never Miss a Deadline Again.png" alt="Automated Reminders">
                    </div>

                    <!-- Text Content Column -->
                    <div class="col-lg-7 col-md-6 col-12">
                        <h2 class="mb-4">Never Miss a Deadline Again — Stay On Track Effortlessly</h2>
                        <p class="mb-4">
                            In today's fast-paced environment, it's easy to let important tasks slip through the cracks.
                            That's why our intelligent reminder system takes the stress out of managing due dates.
                            As soon as a deadline is missed, our platform kicks into action—sending automated email
                            reminders every 24 hours to keep you informed and focused.
                            Whether you're managing client filings, project milestones, or internal tasks,
                            our tool ensures you're always in control, never overwhelmed.
                        </p>

                        <div class="service-features mb-4">
                            <p><i class="fa fa-check text-primary me-2"></i> Daily email notifications</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Configurable reminder intervals</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Escalation alerts for critical deadlines</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Reliable tracking to reduce human error</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Seamless integration with your workflow</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>