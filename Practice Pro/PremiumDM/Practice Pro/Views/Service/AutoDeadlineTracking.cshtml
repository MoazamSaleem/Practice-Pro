@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
}
<!-- Service Content -->
<div class="mt-5 mb-5 pt-5 pb-5">
    <!-- First spacer -->
    <div class="mt-6 mb-6 pt-6 pb-6">
        <!-- Second spacer -->
        <div class="container-xxl py-5 mt-8">
            <!-- Content container -->
            <div class="container">
                <div class="row g-5 align-items-center">
                    <!-- Image Column -->
                    <div class="col-lg-5 col-md-6 col-12">
                        <img class="img-fluid rounded w-100" src="~/finanza-1.0.0/img/Always-Up-To-Date Deadlines.png" alt="Automatic Tracking">
                    </div>

                    <!-- Text Content Column -->
                    <div class="col-lg-7 col-md-6 col-12">
                        <h2 class="mb-4">Always-Up-To-Date Deadlines</h2>
                        <p class="mb-4">
                            Keeping track of compliance deadlines can be stressful and time-consuming—but it doesn’t have to be.
                            Our smart tracking system seamlessly integrates with Companies House to automatically fetch and update
                            critical due dates like your annual Accounts submission and CS01 Confirmation Statement. This means
                            you’ll never miss a deadline, risk penalties, or scramble at the last minute again. Whether you manage
                            one company or a hundred, we keep everything up to date in real time, so you can focus on what matters most—
                            growing your business.
                        </p>

                        <div class="service-features mb-4">
                            <p><i class="fa fa-check text-primary me-2"></i> Real-time Companies House sync</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Change detection alerts</p>
                            <p><i class="fa fa-check text-primary me-2"></i> Historical deadline archive</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>