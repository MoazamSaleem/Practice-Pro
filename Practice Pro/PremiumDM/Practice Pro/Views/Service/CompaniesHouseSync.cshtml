@{
    Layout = "~/Views/Shared/_Layout3.cshtml";
}
<div class="mt-5 mb-5 pt-5 pb-5">
    <!-- First spacer -->
    <div class="mt-6 mb-6 pt-6 pb-6">
        <!-- Second spacer -->
        <div class="container-xxl py-5 mt-8">
            <!-- Content container -->
            <div class="container">
                <div class="row g-5 align-items-center">
                    <!-- Image Column -->
                    <div class="col-lg-5 col-md-6 col-12">
                        <img class="img-fluid rounded w-100" src="~/finanza-1.0.0/img/Companies House Integration.png"
                             alt="Companies House Integration" style="border: 1px solid #dee2e6;">
                    </div>

                    <!-- Text Content Column -->
                    <div class="col-lg-7 col-md-6 col-12">
                        <h2 class="mb-4">Real-Time Companies House Integration</h2>
                        <p class="mb-4">
                            Our service ensures you stay on top of all your client deadlines without the hassle of manual updates.
                            By integrating with Companies House, the system automatically synchronizes your client data, reducing
                            the risk of errors and saving you valuable time. Stay compliant and keep your records up-to-date effortlessly.
                        </p>
                        <p class="mb-4">
                            No more worrying about tracking and updating client company data—our integration allows you to focus on more
                            important tasks while we handle the synchronization. Whether it's updating due dates, keeping an eye on company
                            statuses, or ensuring that all records are accurate, we’ve got you covered!
                        </p>

                        <div class="bg-light p-4 rounded mb-4">
                            <h5 class="text-primary">How It Works:</h5>
                            <ol class="mb-0">
                                <li>Enter the company number once in the provided field.</li>
                                <li>Our system establishes a secure, encrypted API connection to Companies House.</li>
                                <li>After the connection is established, your company data is saved in the system, ensuring seamless integration.</li>
                                <li>Once saved, the company appears in your interactive datatable, ready for further processing or review.</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
